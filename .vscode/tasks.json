{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "dev",
            "path": "frontend/",
            "label": "npm: dev - frontend",
            "detail": "vite",
            "isBackground": true,
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "^\\[vite\\]\\s+error\\s+(.+)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*VITE v\\d+.*$",
                    "endsPattern": "^.*Local:.*http://localhost.*$"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "npm",
            "script": "build",
            "path": "frontend/",
            "label": "npm: build - frontend",
            "detail": "vite build",
            "group": "build"
        },
        {
            "type": "npm",
            "script": "preview",
            "path": "frontend/",
            "label": "npm: preview - frontend",
            "detail": "vite preview",
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}