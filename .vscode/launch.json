{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome (Vite Dev)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*"
            },
            "preLaunchTask": "npm: dev - frontend"
        },
        {
            "name": "Debug Chrome (Attach)",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src"
        }
    ],
    "compounds": [
        {
            "name": "Run & Debug (Vite + Chrome)",
            "configurations": [
                "Launch Chrome (Vite Dev)"
            ]
        }
    ]
}